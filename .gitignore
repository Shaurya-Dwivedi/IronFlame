#setting up gitIgnore for this project.
# Ignore node_modules
node_modules/
# Ignore build output
dist/
build/
# Ignore environment variables
.env
# Ignore logs
logs/
*.log
# Ignore coverage reports
coverage/
# Ignore IDE specific files
.vscode/
.idea/
# Ignore OS specific files
.DS_Store
# Ignore npm debug files
npm-debug.log*
# Ignore yarn debug files
yarn-debug.log*
yarn-error.log*
# Ignore lock files
package-lock.json
yarn.lock
# Ignore test output
test-output/
# Ignore temporary files
tmp/